NODE_ENV = development
PORT = 3500 # PORT IS HERE
SOCKET_PORT = 3501 #TEMP PORT FOR SOCKET
MONGO_URI = mongodb://127.0.0.1:27017/porfira # Dummy MongoDB URI
# URLS
BACKEND_URL = localhost
FRONTEND_URL= http://localhost:3000
# JWT KEYS
JWT_SECRET = your_jwt_secret_key
JWT_ACCESS_EXPIRY = 3d
JWT_REFRESH_EXPIRY = 30d
# BREVO EMAIL CONFIGURATION
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_NAME=Porfira
EMAIL_FROM=user@example.com
# STRIPE ENV
STRIPE_SECRET_KEY= stripe-secret-key
STRIPE_WEBHOOK_SECRET= stripe-webhook-secret
# FIREBASE NOTIFICATION
FIREBASE_PROJECT_ID=dummy-project-id-123456
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xyz@dummy-project-id-123456.iam.gserviceaccount.com
